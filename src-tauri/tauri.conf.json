{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "oiiii",
  "version": "0.1.0",
  "identifier": "com.cds-dn-378.oiiii",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
  "windows": [
    {
      "title": "oiiii",
      "width": 400,
      "height": 300,
      "minWidth": 400,
      "minHeight": 300,
      "resizable": false
    }
  ],
  "security": {
    "csp": null
  }
},
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
